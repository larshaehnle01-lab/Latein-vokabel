function loadNumber(key, fallback = 0) {
  if (typeof window === "undefined") return fallback;
  const v = localStorage.getItem(key);
  return v == null ? fallback : Number(v);
}

function loadJSON(key, fallback) {
  if (typeof window === "undefined") return fallback;
  const v = localStorage.getItem(key);
  if (!v) return fallback;
  try {
    return JSON.parse(v);
  } catch {
    return fallback;
  }
}

function saveState({ coins, learned, streak, best, vocab }) {
  localStorage.setItem(STORAGE_KEY.coins, String(coins));
  localStorage.setItem(STORAGE_KEY.learned, JSON.stringify(learned));
  localStorage.setItem(STORAGE_KEY.streak, String(streak));
  localStorage.setItem(STORAGE_KEY.best, String(best));
  localStorage.setItem(STORAGE_KEY.vocab, JSON.stringify(vocab));
}

